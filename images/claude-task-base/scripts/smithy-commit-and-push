#!/bin/sh
# smithy-commit-and-push — Stage all changes, commit (if any), and push.
#
# Usage: smithy-commit-and-push "commit message" [workdir]
#   workdir defaults to current directory.
set -e

MESSAGE="$1"
WORKDIR="${2:-.}"

cd "$WORKDIR"
echo "[smithy] Committing in $(pwd): $MESSAGE"
git add -A
if ! git diff --cached --quiet; then
  git commit -m "$MESSAGE"
  echo "[smithy] Committed and pushing"
else
  echo "[smithy] No changes to commit"
fi
git push
